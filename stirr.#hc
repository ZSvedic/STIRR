#!/usr/bin/env python3
import glob, os, re
from collections import Counter
TAG_RE = re.compile(r"(?<!\w)#[A-Za-z][\w-]*")
TXT_EXT = set(
    ".txt .md .py .sh .js .ts .java .c .h .cpp .hpp .cs .go .rs "
    ".rb .php .swift .kt .scala .html .css .json .yaml .yml .xml "
    ".toml .ini .cfg".split()
)
def vis(path):
    # Skip hidden files/dirs from traversal and sizing.
    parts = path.split(os.sep)
    return not any(part.startswith(".") and part != "." for part in parts)
def size(path):
    if os.path.isfile(path):
        return os.path.getsize(path)
    files = glob.glob(f"{path}/**/*", recursive=True)
    kept = (p for p in files if os.path.isfile(p) and vis(p))
    return sum(os.path.getsize(p) for p in kept)
def is_parseable(path):
    ext = os.path.splitext(path)[1].lower()
    if os.path.getsize(path) >= 100 * 1024 or ext not in TXT_EXT:
        return False
    return b"\0" not in open(path, "rb").read(4096)
def traverse(root="."):
    print("FILE TREE:")
    walk = glob.glob(f"{root}/**/*", recursive=True)
    paths = [root] + [p for p in walk if vis(p)]
    totals = Counter()
    for p in sorted(paths):
        rel = "." if p == root else os.path.relpath(p, root)
        depth = 0 if rel == "." else rel.count(os.sep) + 1
        tail = "/" if os.path.isdir(p) and rel != "." else ""
        name = "." if rel == "." else os.path.basename(p) + tail
        tags = Counter()
        if os.path.isfile(p) and is_parseable(p):
            txt = open(p, encoding="utf-8", errors="ignore").read()
            tags = Counter(m.group(1).lower() for m in TAG_RE.finditer(txt))
            totals.update(tags)
        top5 = sorted(tags.items(), key=lambda x: (-x[1], x[0]))[:5]
        top = " ".join(f"{c}#{t}" for t, c in top5)
        line = f"{'  ' * depth}{name} {size(p) / 1024:.1f}KB"
        print(line + (f" {top}" if top else ""))
    print("TAG TOTALS:")
    total_pairs = sorted(totals.items(), key=lambda x: (-x[1], x[0]))
    print(" ".join(f"{c}#{t}" for t, c in total_pairs))
if __name__ == "__main__": traverse(".")
