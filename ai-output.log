#"'!/usr/bin/env python3
import glob, os, re
from collections import Counter

TAG_RE = re.compile(r"(?<!'"\\\\w)#[A-Za-z][\\\\w-]*\")


def is_text_file(path):
    try:
        with open(path, \"rb\") as f:
            chunk = f.read(2048)
        return b\"\\x00\" not in chunk
    except Exception:
        return False


def traverse(root=\".\"):
    files, tags_by_file = [], {}
    for path in sorted(glob.glob(os.path.join(root, \"**\", \"*\"), recursive=True)):
        if not os.path.isfile(path):
            continue
        size = os.path.getsize(path)
        if size >= 100 * 1024 or not is_text_file(path):
            continue
        with open(path, encoding=\"utf-8\", errors=\"ignore\") as f:
            tags = Counter(t[1:].lower() for t in TAG_RE.findall(f.read()))
        files.append(path)
        tags_by_file[path] = tags

    dir_sizes = Counter({root: sum(os.path.getsize(p) for p in files)})
    for p in files:
        d = os.path.dirname(p)
        while d.startswith(root):
            dir_sizes[d] += os.path.getsize(p)
            if d == root:
                break
            d = os.path.dirname(d)

    print(\"FILE TREE:\")
    print(f\". {dir_sizes[root] / 1024:.2f}KB\")
    paths = sorted(glob.glob(os.path.join(root, \"**\", \"*\"), recursive=True))
    total_tags = Counter()
    for path in paths:
        rel = os.path.relpath(path, root)
        depth = rel.count(os.sep) + 1
        if os.path.isdir(path):
            print(f\"{'  ' * depth}{os.path.basename(path)}/ \"
                  f\"{dir_sizes[path] / 1024:.2f}KB\")
            continue
        if path not in tags_by_file:
            continue
        total_tags.update(tags_by_file[path])
        top = sorted(tags_by_file[path].items(), key=lambda x: (-x[1], x[0]))[:5]
        tag_str = \" \".join(f\"{c}#{t}\" for t, c in top)
        print(f\"{'  ' * depth}{os.path.basename(path)} \"
              f\"{os.path.getsize(path) / 1024:.2f}KB {tag_str}\".rstrip())

    print(\"TAG TOTALS:\")
    ordered = sorted(total_tags.items(), key=lambda x: (-x[1], x[0]))
    print(\" \".join(f\"{c}#{t}\" for t, c in ordered))


if __name__ == \"__main__\":
    traverse(\".\")
