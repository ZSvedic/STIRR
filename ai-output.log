import glob, os, re
from collections import Counter

TAG_RE = re.compile(r"(?<!'"\\w)#[A-Za-z][\\w-]*\")


def is_text_file(path):
    try:
        with open(path, \"rb\") as f:
            return b\"\\x00\" not in f.read(2048)
    except Exception:
        return False


def traverse(root=\".\"):
    files, tags_by_file = [], {}
    pat = os.path.join(root, \"**\", \"*\")
    for path in sorted(glob.glob(pat, recursive=True)):
        if not os.path.isfile(path):
            continue
        size = os.path.getsize(path)
        if size >= 100 * 1024 or not is_text_file(path):
            continue
        with open(path, encoding=\"utf-8\", errors=\"ignore\") as f:
            tags_by_file[path] = Counter(t[1:].lower() for t in TAG_RE.findall(f.read()))
        files.append(path)

    dir_sizes = Counter()
    for path in files:
        size, d = os.path.getsize(path), os.path.dirname(path)
        # Count parsed-file bytes into each ancestor directory.
        while d.startswith(root):
            dir_sizes[d] += size
            if d == root:
                break
            d = os.path.dirname(d)

    print(\"FILE TREE:\")
    print(f\". {dir_sizes[root] / 1024:.2f}KB\")
    total_tags = Counter()
    for path in sorted(glob.glob(pat, recursive=True)):
        rel, depth = os.path.relpath(path, root), os.path.relpath(path, root).count(os.sep) + 1
        if os.path.isdir(path):
            print(f\"{'  ' * depth}{os.path.basename(path)}/ {dir_sizes[path] / 1024:.2f}KB\")
