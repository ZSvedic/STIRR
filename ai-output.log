@@ -0,0 +1,45 @@
+#!/usr/bin/env python3
+import glob, os, re
+from collections import Counter
+
+TAG_RE = re.compile(r"(?<!\w)#([A-Za-z][A-Za-z0-9+-]*)")
+TXT_EXT = {".txt", ".md", ".py", ".sh", ".js", ".ts", ".java", ".c", ".h", ".cpp", ".hpp", ".cs", ".go", ".rs", ".rb", ".php", ".swift", ".kt", ".scala", ".html", ".css", ".json", ".yaml", ".yml", ".xml", ".toml", ".ini", ".cfg"}
+
+
+def vis(path):
+    # Skip hidden files/dirs from traversal and sizing.
+    return not any(part.startswith(".") and part != "." for part in path.split(os.sep))
+
+
+def size(path):
+    if os.path.isfile(path):
+        return os.path.getsize(path)
+    return sum(os.path.getsize(p) for p in glob.glob(f"{path}/**/*", recursive=True) if os.path.isfile(p) and vis(p))
+
+
+def is_parseable(path):
+    if os.path.getsize(path) >= 100 * 1024 or os.path.splitext(path)[1].lower() not in TXT_EXT:
+        return False
+    return b"\0" not in open(path, "rb").read(4096)
+
+
+def traverse(root="."):
+    print("FILE TREE:")
+    paths = [root] + [p for p in glob.glob(f"{root}/**/*", recursive=True) if vis(p)]
+    totals = Counter()
+    for p in sorted(paths):
+        rel = "." if p == root else os.path.relpath(p, root)
+        depth = 0 if rel == "." else rel.count(os.sep) + 1
+        name = "." if rel == "." else os.path.basename(p) + ("/" if os.path.isdir(p) else "")
+        tags = Counter()
+        if os.path.isfile(p) and is_parseable(p):
+            tags = Counter(m.group(1).lower() for m in TAG_RE.finditer(open(p, encoding="utf-8", errors="ignore").read()))
+            totals.update(tags)
+        top = " ".join(f"{c}#{t}" for t, c in sorted(tags.items(), key=lambda x: (-x[1], x[0]))[:5])
+        print(f"{'  ' * depth}{name} {size(p) / 1024:.1f}KB" + (f" {top}" if top else ""))
+    print("TAG TOTALS:")
+    print(" ".join(f"{c}#{t}" for t, c in sorted(totals.items(), key=lambda x: (-x[1], x[0]))))
+
+
+if __name__ == "__main__":
+    traverse(".")
