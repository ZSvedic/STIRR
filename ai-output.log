#"'!/usr/bin/env python3
import glob, os, re
from collections import Counter

TAG_RE = re.compile(r"(?<!'"\\w)#[A-Za-z][\\w-]*\")


def is_text_file(path):
    try:
        with open(path, \"rb\") as f:
            return b\"\\x00\" not in f.read(2048)
    except Exception:
        return False


def traverse(root=\".\"):
    pat = os.path.join(root, \"**\", \"*\")
    files, tags_by_file, dir_sizes = [], {}, Counter()
    for path in sorted(glob.glob(pat, recursive=True)):
        if not os.path.isfile(path):
            continue
        size = os.path.getsize(path)
        if size >= 100 * 1024 or not is_text_file(path):
            continue
        with open(path, encoding=\"utf-8\", errors=\"ignore\") as f:
            tags = Counter(t[1:].lower() for t in TAG_RE.findall(f.read()))
        files.append(path)
        tags_by_file[path] = tags
        d = os.path.dirname(path)
        # Count parsed-file bytes into each ancestor directory.
        while d.startswith(root):
            dir_sizes[d] += size
            if d == root:
                break
            d = os.path.dirname(d)

    print(\"FILE TREE:\")
    print(f\". {dir_sizes[root] / 1024:.2f}KB\")
    total_tags = Counter()
    for path in sorted(glob.glob(pat, recursive=True)):
        rel = os.path.relpath(path, root)
        depth = rel.count(os.sep) + 1
        if os.path.isdir(path):
            size = dir_sizes[path] / 1024
            print(f\"{'  ' * depth}{os.path.basename(path)}/ {size:.2f}KB\")
            continue
        if path not in tags_by_file:
            continue
        total_tags.update(tags_by_file[path])
        top = sorted(tags_by_file[path].items(), key=lambda x: (-x[1], x[0]))[:5]
        tags = \" \".join(f\"{c}#{t}\" for t, c in top)
        size = os.path.getsize(path) / 1024
        print(f\"{'  ' * depth}{os.path.basename(path)} {size:.2f}KB {tags}\".rstrip())

    print(\"TAG TOTALS:\")
    out = sorted(total_tags.items(), key=lambda x: (-x[1], x[0]))
    print(\" \".join(f\"{c}#{t}\" for t, c in out))


if __name__ == \"__main__\":
    traverse(\".\")
