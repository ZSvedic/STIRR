#"'!/usr/bin/env python3
import glob, os, re
from collections import Counter

TAG_RE = re.compile(r"(?<!'"\\w)#[A-Za-z][\\w-]*\")

def is_text_file(path):
    try:
        with open(path, 'rb') as f:
            chunk = f.read(4096)
        return b'\\x00' not in chunk
    except:
        return False

def _visible(path):
    return not any(part.startswith('.') and part "'!= '"'.' for part in path.split(os.sep))

def _size(path):
    if os.path.isfile(path): return os.path.getsize(path)
    return sum(os.path.getsize(p) for p in glob.glob(f\"{path}/**/*\", recursive=True) if os.path.isfile(p) and _visible(p))

def traverse(root=\".\"):
    print(\"FILE TREE:\")
    paths = [root] + [p for p in glob.glob(f\"{root}/**/*\", recursive=True) if _visible(p)]
    totals = Counter()
    for p in sorted(paths):
        rel = \".\" if p == root else os.path.relpath(p, root)
        depth = 0 if rel == \".\" else rel.count(os.sep) + 1
        name = \".\" if rel == \".\" else os.path.basename(p) + (\"/\" if os.path.isdir(p) else \"\")
        tags = Counter()
        if os.path.isfile(p) and os.path.getsize(p) < 100 * 1024 and is_text_file(p):
            with open(p, encoding=\"utf-8\", errors=\"ignore\") as f: tags.update(t.lower() for t in TAG_RE.findall(f.read()))
            totals.update(tags)
        top = \" \".join(f\"{c}#{t}\" for t, c in sorted(tags.items(), key=lambda x: (-x[1], x[0]))[:5])
        print(f\"{'  ' * depth}{name} {_size(p) / 1024:.2f}KB\" + (f\" {top}\" if top else \"\"))
    print(\"TAG TOTALS:\")
    print(\" \".join(f\"{c}#{t}\" for t, c in sorted(totals.items(), key=lambda x: (-x[1], x[0]))))

if __name__ == \"__main__\":
    traverse(\".\")
