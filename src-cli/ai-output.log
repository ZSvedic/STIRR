#"'!/usr/bin/env python3
import glob
import os
import re
import sys
from collections import Counter

TAG_RE = re.compile(r"(?<!'"\\w)#[A-Za-z][\\w-]*\")
RULE_TAGS = \"#TextRL #ConventionRL #SDD #TDD #ImplementRL #HITL #RepeatRL\"
MAX_TEXT_FILE_SIZE = 128 * 1024
HELP_TEXT = \"\"\"USAGE:
  stirr.py [--dry-run] PATH1 [PATH2 ...]
  stirr.py --help

  <PATHx> ...
      A file(s)/dir(s) to check.
\"\"\"


def fmt_kb(num_bytes):
    return f\"{num_bytes / 1024:.2f}KB\"


def norm(tag):
    return tag.lower()


def get_file_text_hashtag(path):
    try:
        with open(path, \"rb\") as f:
            chunk = f.read(4096)
        if b\"\\x00\" in chunk:
            return (False, None)
        text = chunk.decode(\"utf-8\", \"ignore\")
        m = TAG_RE.search(text)
        return (True, m.group(0) if m else None)
    except Exception:
        return (False, None)


def get_text_file_info(path):
    try:
        size = os.path.getsize(path)
    except OSError:
        return None
    if size >= MAX_TEXT_FILE_SIZE:
        return None

    is_text, first = get_file_text_hashtag(path)
    if not is_text:
        return None

    try:
        with open(path, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:
            text = f.read()
    except OSError:
        return None

    counts = Counter(norm(t) for t in TAG_RE.findall(text))
    return {
        \"path\": os.path.abspath(path),
        \"name\": os.path.basename(path),
        \"size\": size,
        \"first_tag\": first,
        \"counts\": counts,
    }


def iter_paths(root):
    if os.path.isfile(root):
        return [root]
    if os.path.isdir(root):
        return glob.glob(os.path.join(root, \"**\", \"*\"), recursive=True)
    return []


def traverse(paths):
    roots = [paths] if isinstance(paths, str) else list(paths)
    files, totals, dir_sizes = [], Counter(), Counter()

    for root in roots:
        for p in iter_paths(root):
            if not os.path.isfile(p):
                continue
            info = get_text_file_info(p)
            if not info:
                continue
            files.append(info)
            totals.update(info[\"counts\"])

            d = os.path.dirname(info[\"path\"])
            while True:
                dir_sizes[d] += info[\"size\"]
                nd = os.path.dirname(d)
                if nd == d:
                    break
                d = nd

    files.sort(key=lambda x: x[\"path\"])
    return {
        \"roots\": [os.path.abspath(p) for p in roots],
        \"files\": files,
        \"dirs\": dict(dir_sizes),
        \"totals\": totals,
    }


def top_counts(counts, limit=5):
    return sorted(counts.items(), key=lambda x: (-x[1], x[0]))[:limit]


def format_counts(items):
    return \" \".join(f\"{v}{k}\" for k, v in items)


def print_file_info(info):
    top = top_counts(info[\"counts\"], 5)
    ft = info[\"first_tag\"] or \"-\"
    extra = f\" ({format_counts(top)})\" if top else \"\"
    print(f\"  {info['name']} {fmt_kb(info['size'])} {ft}{extra}\")


def print_file_tree(data):
    print(\"FILE TREE:\")
    roots = data[\"roots\"]
    files = data[\"files\"]
    root_files = {r: [] for r in roots}

    for f in files:
        fpath = f[\"path\"]
        for r in roots:
            rp = os.path.join(r, \"\")
            if fpath == r or fpath.startswith(rp):
                root_files[r].append(f)
                break

    for root in roots:
        label = os.path.basename(root.rstrip(os.sep)) or root
        if os.path.isfile(root):
            size = os.path.getsize(root) if os.path.exists(root) else 0
            print(f\"{label} {fmt_kb(size)}\")
            continue

        rsize = sum(f[\"size\"] for f in root_files[root])
        print(f\"{label}/ {fmt_kb(rsize)}\")
        for f in root_files[root]:
            print_file_info(f)


def print_hahstags(data):
    print(\"TAG TOTALS:\")
    totals = top_counts(data[\"totals\"], len(data[\"totals\"]))
    print(format_counts(totals) if totals else \"(none)\")


def print_api_keys():
    print(\"API KEYS:\")
    print(f\"OPENAI_API_KEY={os.getenv('OPENAI_API_KEY', '')}\")
    print(f\"ANTHROPIC_API_KEY={os.getenv('ANTHROPIC_API_KEY', '')}\")


def print_all(data):
    print(f\"RULE TAGS: {RULE_TAGS}\")
    print_file_tree(data)
    print_hahstags(data)
    print_api_keys()


def parse_args(argv):
    if any(a in (\"-h\", \"--help\") for a in argv):
        return True, False, []

    dry = False
    paths = []
    for a in argv:
        if a == \"--dry-run\":
            dry = True
        else:
            paths.append(a)

    return False, dry, paths


def main(argv=None):
    argv = sys.argv[1:] if argv is None else argv
    show_help, dry, paths = parse_args(argv)
    if show_help or not paths:
        print(HELP_TEXT.rstrip())
        return 0

    data = traverse(paths)
    if dry:
        print(\"DRY RUN\")
    print_all(data)
    return 0


if __name__ == \"__main__\":
    raise SystemExit(main())
