#"'!/usr/bin/env python3
# #AI

import glob, os, re
from collections import Counter

TAG_RE = re.compile(r"(?<!'"\\w)#[A-Za-z][\\w-]*\")
GLOBAL_TAGS = set()


def get_file_text_hashtag(path):
    try:
        with open(path, 'rb') as f:
            chunk = f.read(4096)
        if b'\\x00' in chunk:
            return (False, None)
        m = TAG_RE.search(chunk.decode('utf-8', 'ignore'))
        return (True, m.group(0) if m else None)
    except Exception:
        return (False, None)


def get_text_file_info(path):
    size = os.path.getsize(path)
    if size >= 128 * 1024:
        return (size, False, None, Counter())
    ok, first = get_file_text_hashtag(path)
    if not ok:
        return (size, False, None, Counter())
    with open(path, encoding='utf-8', errors='ignore') as f:
        return (size, True, first,
                Counter(t.lower() for t in TAG_RE.findall(f.read())))


def traverse(root='.'):
    files, dirs, totals = [], Counter(), Counter()
    for p in sorted(glob.glob(os.path.join(root, '**', '*'), recursive=True)):
        if not os.path.isfile(p):
            continue
        size, ok, first, tags = get_text_file_info(p)
        if not ok:
            continue
        rel, drel = os.path.relpath(p, root), os.path.dirname(os.path.relpath(p, root))
        depth = rel.count(os.sep) + 1
        files.append((depth, drel, os.path.basename(p), size, first or '-', tags))
        if drel:
            dirs[drel] += size
        GLOBAL_TAGS.update(tags)
        totals.update(tags)
    return {'root_kb': sum(f[3] for f in files) / 1024,
            'files': files, 'dirs': dirs, 'totals': totals}


def print_file_tree(info):
    print('FILE TREE:')
    print(f\". {info['root_kb']:.2f}KB\")


def print_file_info(item):
    d, _, name, size, first, tags = item
    top = ' '.join(f'{c}{t}' for t, c in tags.most_common(5))
    print(f\"{'  ' * d}{name} {size / 1024:.2f}KB {first} ({top})\")


def print_hahstags(totals):
    print('TAG TOTALS:')
    print(' '.join(f'{c}{t}' for t, c in totals.most_common()))


def print_all(info, rules='../STIRR-rules.md'):
    print('RULE TAGS:')
    try:
        with open(rules, encoding='utf-8') as f:
            print(' '.join(TAG_RE.search(l).group(0) for l in f if l.startswith('### ')))
    except Exception:
        print('-')
    print_file_tree(info)
    seen = set()
    for item in info['files']:
        d, drel = item[0], item[1]
        if drel and drel not in seen:
            print(f\"{'  ' * d}{drel}/ {info['dirs'][drel] / 1024:.2f}KB\")
            seen.add(drel)
        print_file_info(item)
    print_hahstags(info['totals'])


if __name__ == '__main__':
    print_all(traverse('.'))
